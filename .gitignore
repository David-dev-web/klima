# Comprehensive .gitignore for Klima Flutter Project

# --- Flutter / Dart ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/
doc/api/
.last_build_id

# --- Android ---
.gradle/
local.properties
*.iml
*.ipr
*.iws
.idea/
/android/app/debug
/android/app/profile
/android/app/release
/android/key.properties
**/android/Captures/
**/android/.externalNativeBuild/
**/android/.cxx/
**/android/*.iml
**/android/app/src/main/res/raw/
**/android/app/src/main/assets/
# Ignore generated APKs/Bundles
*.apk
*.aab

# --- iOS ---
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Flutter/App.framework
**/ios/Flutter/App.podspec
**/ios/Pods/
**/ios/.symlinks/
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/Runner/Info.plist.tmp
**/ios/Runner/config.json
*.xcworkspace
*.xcuserdata
*.xccheckout
*.xcscmblueprint
DerivedData/

# --- VS Code ---
.vscode/

# --- Sensitive Data (.env / Keys) ---
.env
.env.*
*.env
secrets.json
key_config.yml
key.jks
*.keystore

# --- Miscellaneous ---
*.class
*.log
*.pyc
*.swp
.DS_Store
.history
.svn/
.idea/
crashlytics-debug.manifest
**/doc/api/
**/*.symbols
**/*.map.json
